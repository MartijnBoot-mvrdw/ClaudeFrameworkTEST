<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010" x:Class="AppName_Launch"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:uix="http://schemas.uipath.com/workflow/activities/uix"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib"
  xmlns:uia="clr-namespace:UiPath.UIAutomationNext;assembly=UiPath.UIAutomation">
  <x:Members>
    <x:Property Name="out_uiApp" Type="OutArgument(uix:UiElement)" />
  </x:Members>
  <Sequence DisplayName="Main" sap:VirtualizedContainerService.HintSize="400,300" sap2010:WorkflowViewState.IdRef="Sequence_1">
    
    <uix:NApplicationCard DisplayName="Use Browser" OpenMode="OpenIfNotOpen"
      OutUiElement="[out_uiApp]"
      ScopeGuid="aaaaaaaa-0000-0000-0000-000000000001"
      sap2010:WorkflowViewState.IdRef="NApplicationCard_1">
      <uix:NApplicationCard.Body>
        <Sequence DisplayName="Body" sap2010:WorkflowViewState.IdRef="Seq_Body_1">
          <ui:GetRobotCredential AssetName="WebApp_Cred" Username="[strUser]" Password="[secstrPass]"
            sap2010:WorkflowViewState.IdRef="GetRobotCredential_1" />
          <uix:NTypeInto DisplayName="Type User" Text="[strUser]"
            ScopeIdentifier="aaaaaaaa-0000-0000-0000-000000000001"
            sap2010:WorkflowViewState.IdRef="NTypeInto_1">
            <uix:NTypeInto.Target>
              <uix:TargetAnchorable FullSelectorArgument="&lt;webctrl tag='INPUT' /&gt;" 
                SearchSteps="Selector" Guid="00000000-0000-0000-0000-000000000001" Version="V6" WaitForReadyArgument="Interactive" />
            </uix:NTypeInto.Target>
          </uix:NTypeInto>
          <uix:NClick DisplayName="Click Login"
            ScopeIdentifier="aaaaaaaa-0000-0000-0000-000000000001"
            sap2010:WorkflowViewState.IdRef="NClick_1">
            <uix:NClick.Target>
              <uix:TargetAnchorable FullSelectorArgument="&lt;webctrl tag='BUTTON' /&gt;" 
                SearchSteps="Selector" Guid="00000000-0000-0000-0000-000000000002" Version="V6" WaitForReadyArgument="Interactive" />
            </uix:NClick.Target>
          </uix:NClick>
        </Sequence>
      </uix:NApplicationCard.Body>
    </uix:NApplicationCard>
  </Sequence>
</Activity>