<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010" x:Class="Bad_HallucinatedProps"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:uix="http://schemas.uipath.com/workflow/activities/uix"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation">
  <Sequence DisplayName="Main" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <!-- Bug 1: Url on NApplicationCard instead of TargetApp -->
    <uix:NApplicationCard DisplayName="Use Browser" Url="https://example.com"
      sap2010:WorkflowViewState.IdRef="NApplicationCard_1" />
    <!-- Bug 2: bare Selector on TargetAnchorable -->
    <uix:NClick DisplayName="Click">
      <uix:NClick.Target>
        <uix:TargetAnchorable Selector="&lt;webctrl tag='BUTTON' /&gt;" />
      </uix:NClick.Target>
    </uix:NClick>
    <!-- Bug 3: uix:Selector element -->
    <uix:Selector DisplayName="Check Loaded" />
    <!-- Bug 4: AnchorSelector on TargetAnchorable -->
    <uix:NGetText DisplayName="Get Text">
      <uix:NGetText.Target>
        <uix:TargetAnchorable FullSelectorArgument="&lt;webctrl tag='SPAN' /&gt;" AnchorSelector="&lt;webctrl tag='LABEL' /&gt;" />
      </uix:NGetText.Target>
    </uix:NGetText>
    <!-- Bug 5: Appears on NCheckState -->
    <uix:NCheckState DisplayName="Check State" Appears="True"
      sap2010:WorkflowViewState.IdRef="NCheckState_1" />
    <!-- Bug 6: ClickBeforeTyping (should be ClickBeforeMode) -->
    <uix:NTypeInto DisplayName="Type Email" ClickBeforeTyping="True" EmptyField="True"
      Text="[strEmail]" sap2010:WorkflowViewState.IdRef="NTypeInto_1">
      <!-- Bug 7: .TargetAnchorable child element (should be .Target) -->
      <uix:NTypeInto.TargetAnchorable>
        <uix:TargetAnchorable FullSelectorArgument="&lt;webctrl tag='INPUT' /&gt;" />
      </uix:NTypeInto.TargetAnchorable>
    </uix:NTypeInto>
  </Sequence>
</Activity>
