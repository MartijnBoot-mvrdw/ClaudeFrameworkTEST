<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010" x:Class="Bad_NoIncognito"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:uix="http://schemas.uipath.com/workflow/activities/uix"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation">
  <Sequence DisplayName="Main" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <uix:NApplicationCard AttachMode="SingleWindow" CloseMode="Never"
      DisplayName="Use Browser Edge" InteractionMode="DebuggerApi"
      OpenMode="Never" sap2010:WorkflowViewState.IdRef="NApplicationCard_1" Version="V2">
      <uix:NApplicationCard.TargetApp>
        <uix:TargetApp BrowserType="Edge" Url="[in_strUrl]" />
      </uix:NApplicationCard.TargetApp>
    </uix:NApplicationCard>
  </Sequence>
</Activity>
