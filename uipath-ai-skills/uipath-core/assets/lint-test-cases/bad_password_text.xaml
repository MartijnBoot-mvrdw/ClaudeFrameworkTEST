<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010" x:Class="Bad_PasswordText"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:uix="http://schemas.uipath.com/workflow/activities/uix"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation">
  <Sequence DisplayName="Main" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <uix:NTypeInto DisplayName="Type Into 'Password'" Text="[strPassword]"
      sap2010:WorkflowViewState.IdRef="NTypeInto_1">
      <uix:NTypeInto.Target>
        <uix:TargetAnchorable>
          <uix:TargetAnchorable.FullSelectorArgument>
            <InArgument x:TypeArguments="x:String">&lt;webctrl tag='INPUT' type='password' /&gt;</InArgument>
          </uix:TargetAnchorable.FullSelectorArgument>
        </uix:TargetAnchorable>
      </uix:NTypeInto.Target>
    </uix:NTypeInto>
  </Sequence>
</Activity>
